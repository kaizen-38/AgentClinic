# AgentClinic secrets — DO NOT COMMIT TO GIT
# Copy this to ~/.agentclinic_secrets and chmod 600 it:
#   cp .env.example ~/.agentclinic_secrets
#   chmod 600 ~/.agentclinic_secrets
#
# Then fill in your actual keys below (get them from the ASU RC portal).

# Voyager API (ASU RC OpenAI-compatible endpoint)
export VOYAGER_API_KEY="YOUR_VOYAGER_API_KEY_HERE"
export VOYAGER_API_BASE="https://openai.rc.asu.edu/v1"

# Optional: rotate through multiple Voyager keys for high concurrency
export VOYAGER_API_KEYS="key1,key2,key3"

# Optional: standard OpenAI key (only needed if you use gpt4/gpt4o directly)
# export OPENAI_API_KEY=""
